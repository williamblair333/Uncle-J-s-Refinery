{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "git add -A 2>/dev/null; git diff --cached --quiet && exit 0; git commit -m \"chk: $(date +%H:%M:%S)\" -q 2>/dev/null || true",
            "statusMessage": "Checkpointing..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import json,sys,datetime,os; d=json.load(sys.stdin); p=os.path.expanduser('~/.claude/state/mcp-tool-log.txt'); os.makedirs(os.path.dirname(p),exist_ok=True); open(p,'a').write('[{}] {}\\n'.format(datetime.datetime.now().strftime('%H:%M:%S'),d.get('tool_name','?')))\" 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__jcodemunch__search_text",
      "mcp__jcodemunch__index_file",
      "mcp__jcodemunch__get_file_content",
      "mcp__mempalace__mempalace_search",
      "mcp__jcodemunch__list_repos",
      "mcp__jcodemunch__get_symbol_source",
      "Bash(crontab -l)"
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "ralph-wiggum@claude-code-plugins": true
  }
}
