# ─────────────────────────────────────────────────────────────────────────
# Uncle J's Refinery — .gitignore
# ─────────────────────────────────────────────────────────────────────────

# ── Python virtual environments (regenerated by install.ps1) ────────────
.venv/
.venv-test/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.Python

# ── uv / pip caches ─────────────────────────────────────────────────────
.uv-cache/
pip-log.txt
pip-wheel-metadata/

# ── Secrets. NEVER COMMIT. ──────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.template
!.env.sample
*.key
*.pem
*.p12
*.pfx
*credentials*
*secret*
# The Langfuse template generates .env with live passwords; keep it out.
claude-code-langfuse-template/.env

# ── Third-party clones — re-cloned fresh by the installers ──────────────
# install-reliability.ps1 clones claude-guardrails
# install-langfuse.ps1 clones claude-code-langfuse-template
claude-guardrails/
claude-code-langfuse-template/
claude-code-langfuse-template.skeleton.*/

# ── Rendered MCP client configs (install.{sh,ps1} regenerates from .tmpl) ─
mcp-clients/*.json
!mcp-clients/*.json.tmpl

# ── Runtime state (not source) ──────────────────────────────────────────
state/
state/*.log
*.log
langfuse_hook.log
pending_traces.jsonl
langfuse_state.json

# ── Backups made by installers or manual edits ──────────────────────────
*.bak
*.bak.*
*~

# ── Docker ──────────────────────────────────────────────────────────────
docker-compose.override.yml
.docker/

# ── OS noise ────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store
.AppleDouble
.LSOverride

# ── IDE / editor ────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── Claude Code project-local overrides (should stay local) ─────────────
.claude/settings.local.json

# ── Node (from any npm-installed MCP server experiments) ────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build outputs ───────────────────────────────────────────────────────
dist/
build/
out/

# ── Test artifacts ──────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Temporary files ─────────────────────────────────────────────────────
*.tmp
*.temp
.fuse_hidden*

# ── Session transcripts from Cowork / Claude Code (may contain secrets) ─
cowork-history.txt
*-history.txt
session-history.*
*-installer.txt

# MemPalace per-project files (issue #185)
mempalace.yaml
entities.json
