{
  "_comment": "Generated from claude-code-mcp.json.tmpl by install.sh. Drop the rendered mcp-clients/claude-code-mcp.json as .mcp.json at your project root, OR run install.sh --auto-register to register user-scope with `claude mcp add`.",
  "_comment_serena_context": "Serena's context defaults to 'ide-assistant' for Claude Code. Use 'desktop-app' for Claude Desktop instead.",
  "_comment_placeholders": "{{STACK_VENV_BIN}} -> absolute path to the venv binary dir ",

  "mcpServers": {
    "jcodemunch": {
      "type": "stdio",
      "command": "{{STACK_VENV_BIN}}/jcodemunch-mcp{{EXE}}"
    },
    "jdatamunch": {
      "type": "stdio",
      "command": "{{STACK_VENV_BIN}}/jdatamunch-mcp{{EXE}}"
    },
    "jdocmunch": {
      "type": "stdio",
      "command": "{{STACK_VENV_BIN}}/jdocmunch-mcp{{EXE}}"
    },
    "mempalace": {
      "type": "stdio",
      "command": "{{STACK_VENV_BIN}}/python{{EXE}}",
      "args": ["-m", "mempalace.mcp_server"]
    },
    "serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from", "git+https://github.com/oraios/serena",
        "serena", "start-mcp-server",
        "--context", "ide-assistant"
      ]
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {
        "CONTEXT7_API_KEY": ""
      }
    },
    "duckdb": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-motherduck",
        "--db-path", ":memory:",
        "--read-write",
        "--allow-switch-databases"
      ]
    }
  }
}
