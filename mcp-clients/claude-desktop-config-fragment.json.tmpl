{
  "_comment": "Generated from claude-desktop-config-fragment.json.tmpl by install.{sh,ps1}. Paste the `mcpServers` entries below into your Claude Desktop config at:",
  "_comment_windows": "  %APPDATA%\\Claude\\claude_desktop_config.json",
  "_comment_macos":   "  ~/Library/Application Support/Claude/claude_desktop_config.json",
  "_comment_linux":   "  ~/.config/Claude/claude_desktop_config.json",
  "_comment_placeholders": "{{STACK_VENV_BIN}} -> absolute path to the venv binary dir (.venv/bin on Linux, .venv/Scripts on Windows). {{EXE}} -> '.exe' on Windows, empty on Linux.",
  "_comment_context7": "Context7 API key is optional; remove --api-key arg to use the free anonymous tier.",

  "mcpServers": {
    "jcodemunch": {
      "command": "{{STACK_VENV_BIN}}/jcodemunch-mcp{{EXE}}"
    },
    "jdatamunch": {
      "command": "{{STACK_VENV_BIN}}/jdatamunch-mcp{{EXE}}"
    },
    "jdocmunch": {
      "command": "{{STACK_VENV_BIN}}/jdocmunch-mcp{{EXE}}"
    },
    "mempalace": {
      "command": "{{STACK_VENV_BIN}}/python{{EXE}}",
      "args": ["-m", "mempalace.mcp_server"]
    },
    "serena": {
      "command": "uvx",
      "args": [
        "--from", "git+https://github.com/oraios/serena",
        "serena", "start-mcp-server",
        "--context", "desktop-app"
      ]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {
        "CONTEXT7_API_KEY": ""
      }
    },
    "duckdb": {
      "command": "uvx",
      "args": [
        "mcp-server-motherduck",
        "--db-path", ":memory:",
        "--read-write",
        "--allow-switch-databases"
      ]
    }
  }
}
